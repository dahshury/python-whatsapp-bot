# Turso Local Development Database Configuration
# Copy this file to .env for local development

# Turso Local Database File Path (default: threads_db_turso.sqlite in project root)
DB_PATH=./threads_db_turso.sqlite

# WebSocket Server Configuration (for real-time updates)
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765

# Frontend WebSocket URL (for local development)
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8765

# Python Backend URL (if different from default)
# PYTHON_BACKEND_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000

# Note: No cloud credentials needed! Everything runs locally just like before
# but with async operations and real-time WebSocket updates 